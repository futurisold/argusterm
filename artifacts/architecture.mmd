graph TD
    subgraph Feeds["Feed Sources (20+ RSS/Atom)"]
        CISA["CISA Advisories"]
        GHSA["GitHub Advisories"]
        NEWS["Security News<br/>(Krebs, Schneier, etc.)"]
        RSCH["Research Blogs<br/>(Securelist, Qualys, etc.)"]
        XPLT["Exploit-DB"]
        CERT["CERT/CC"]
    end

    subgraph Ingest["Ingest Pipeline"]
        POLL["reqwest Async Poller<br/>(configurable interval)"]
        PARSE["feed-rs Parser<br/>+ HTML Stripping"]
        DEDUP["Dedup by Entry ID"]
        DATE["days_lookback Filter"]
    end

    subgraph Scrape["Page Scraping"]
        PARALLEL["Parallel.ai Extract API<br/>(full page content)"]
        FALLBACK["Fallback: RSS description"]
    end

    subgraph LLM["LLM Triage (Anthropic API)"]
        SEM["Semaphore Gate<br/>(max_concurrent)"]
        PROMPT["Jinja2 Prompt Templates<br/>(prompts/*.j2)"]
        SCHEMA["Structured JSON Output"]
        CLASSIFY["Content Classification<br/>(cve/advisory/news/<br/>research/promotional/irrelevant)"]
        SCORE["AI-Security Relevance<br/>Score (0.0-1.0)"]
        DOT["Graphviz DOT Diagram"]
        CVES["CVE ID Extraction"]
    end

    subgraph Render["graph-easy (Perl)"]
        ASCII["DOT → ASCII<br/>Box-and-Arrow Diagrams"]
    end

    subgraph Storage["SQLite Cache"]
        DB[(".argusterm/cache.db<br/>Persistent across restarts")]
    end

    subgraph TUI["ratatui TUI"]
        LIST["Feed List Panel (38%)<br/>[score] SRC date title"]
        DETAIL["Detail Panel (62%)<br/>Summary + Diagram"]
        FILTER["Filter Bar<br/>(text search + sort)"]
        CVEBAR["CVE Bar<br/>(navigate → open NVD)"]
        STATUS["Status Bar<br/>(keybindings + progress)"]
    end

    Feeds --> POLL
    POLL --> PARSE --> DEDUP --> DATE
    DATE --> DB
    DATE --> PARALLEL
    PARALLEL -->|success| SEM
    PARALLEL -->|fail| FALLBACK --> SEM
    SEM --> PROMPT --> SCHEMA
    SCHEMA --> CLASSIFY
    SCHEMA --> SCORE
    SCHEMA --> DOT
    SCHEMA --> CVES
    DOT --> ASCII
    CLASSIFY --> DB
    SCORE --> DB
    ASCII --> DB
    CVES --> DB
    DB --> TUI
